package = pcap
headers = pcap/pcap.h
# Only the fetched libpcap API headers are used; system headers (sys/types.h, ...) come from the
# Kotlin/Native sysroot. Pointing at the host /usr/include drags in glibc headers that break on
# multiarch distros and is absent on macOS, so it is deliberately not used.
compilerOpts = -Isrc/nativeInterop/pcap-headers
linkerOpts = -L/usr/lib -L/usr/lib/x86_64-linux-gnu -lpcap
